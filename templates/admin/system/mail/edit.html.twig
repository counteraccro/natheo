{% extends 'admin/admin_base.html.twig' %}

{% block title %}{{ 'mail.edit_page_title' | trans({}, 'mail') }}{% endblock %}

{% block body %}

    {{ breadcrumb(breadcrumb) }}

    <h1 class="head-title">
        <svg class="w-7 h-7 text-(--primary)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="m3.5 5.5 7.893 6.036a1 1 0 0 0 1.214 0L20.5 5.5M4 19h16a1 1 0 0 0 1-1V6a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1Z"></path>
        </svg>
        {{ 'mail.edit_page_title_h1' | trans({}, 'mail') }}</h1>

    {% if mail %}

        {% set title =  mail.title | trans({}) %}
        <p class="text-sm text-(--text-secondary) mb-3">{{ 'mail.edit_page_description' | trans({'email' : title}, 'mail') | raw }}</p>


        <div {{ vue_component('Admin/System/Mail', {'url_data' : path('admin_mail_load_data', {'id' : mail.id})}) }}></div>

    {% else  %}

        <div class="flex flex-col items-center justify-center py-16 px-6 text-center">
            <!-- Icône -->
            <div
                class="w-16 h-16 rounded-2xl flex items-center justify-center mb-5"
                style="background-color: var(--primary-lighter);"
            >
                <svg class="w-8 h-8" style="color: var(--primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m3.5 5.5 7.893 6.036a1 1 0 0 0 1.214 0L20.5 5.5M4 19h16a1 1 0 0 0 1-1V6a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1Z"/>
                </svg>
            </div>

            <!-- Titre -->
            <p class="text-lg font-bold mb-2" style="color: var(--text-primary);">
                {{ 'mail.edit_page.no.mail.title' | trans({}, 'mail') }}</h1>
            </p>

            <!-- Description -->
            <p class="text-sm max-w-xs mb-6" style="color: var(--text-secondary);">
                {{ 'mail.edit_page.no.mail.text' | trans({}, 'mail') }}</h1>
            </p>

            <!-- Boutons -->
            <div class="flex items-center gap-3">
                <a href="{{ path('admin_mail_index') }}" class="btn btn-sm btn-outline-dark flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                    </svg>
                    {{ 'mail.edit_page.no.mail.back' | trans({}, 'mail') }}</h1>
                </a>
            </div>
        </div>

    {% endif %}

{% endblock %}
