{% extends 'admin/admin_base.html.twig' %}

{% if tag is same as null %}
    {% set title = 'tag.update.page_title' | trans({'id' : '-'}, 'tag') %}
    {% set titleH1 = 'tag.update.page_title_h1' | trans({}, 'tag') %}
    {% set description = 'tag.update.description' | trans({}, 'tag') %}
{% elseif tag.id is same as null %}
    {% set title = 'tag.add.page_title' | trans({}, 'tag') %}
    {% set titleH1 = 'tag.add.page_title_h1' | trans({}, 'tag') %}
    {% set description = 'tag.add.description' | trans({}, 'tag') %}
    {% set url_stats = '' %}
    {% set url_update = '' %}
    {% set url_delete = ''%}
{% else %}
    {% set title = 'tag.update.page_title' | trans({'id' : tag.id}, 'tag') %}
    {% set titleH1 = 'tag.update.page_title_h1' | trans({}, 'tag') %}
    {% set description = 'tag.update.description' | trans({}, 'tag') %}
    {% set url_stats =  path('admin_tag_stats', {'id' : tag.id}) %}
    {% set url_update =  path('admin_tag_update', {'id' : tag.id}) %}
    {% set url_delete = path('admin_tag_delete', {'id' : tag.id}) %}
{% endif %}

 {% block title %}
     {{ title }}
 {% endblock %}

{% block body %}

    {{ breadcrumb(breadcrumb) }}

    <h1 class="head-title">
        <svg class="w-7 h-7" style="color: var(--primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.2 6H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h11.2a1 1 0 0 0 .747-.334l4.46-5a1 1 0 0 0 0-1.332l-4.46-5A1 1 0 0 0 15.2 6Z"></path>
        </svg>
        {{ titleH1 }}</h1>

    <p class="text-sm text-[var(--text-secondary)] mb-3">
        {{ description }}
    </p>


    {% if tag is same as null %}
        <div class="flex flex-col items-center justify-center py-16 px-6 text-center">
            <!-- Icône -->
            <div
                class="w-16 h-16 rounded-2xl flex items-center justify-center mb-5"
                style="background-color: var(--primary-lighter);"
            >
                <svg class="w-8 h-8" style="color: var(--primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.2 6H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h11.2a1 1 0 0 0 .747-.334l4.46-5a1 1 0 0 0 0-1.332l-4.46-5A1 1 0 0 0 15.2 6Z"/>
                </svg>
            </div>

            <!-- Titre -->
            <p class="text-lg font-bold mb-2" style="color: var(--text-primary);">
                {{ 'tag.update.page.no.tag.title' | trans({}, 'tag') }}
            </p>

            <!-- Description -->
            <p class="text-sm max-w-xs mb-6" style="color: var(--text-secondary);">
                {{ 'tag.update.page.no.tag.text' | trans({}, 'tag') }}
            </p>

            <!-- Boutons -->
            <div class="flex items-center gap-3">
                <a href="{{ path('admin_tag_index') }}" class="btn btn-sm btn-outline-dark flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                    </svg>
                    {{ 'tag.update.page.back' | trans({}, 'tag') }}
                </a>
                <a href="{{ path('admin_tag_add') }}" class="btn btn-sm btn-primary flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                    {{ 'tag.update.page.new' | trans({}, 'tag')}}
                </a>
            </div>
        </div>
    {% else  %}

        <div {{ vue_component('Admin/Content/TagForm', {
            'url' : path('admin_tag_save'),
            'url_update' : url_update,
            'url_stats' : url_stats,
            'url_index' : path('admin_tag_index'),
            'url_delete' : url_delete,
            'pTag' : tag,
            'translate' : translate,
            'locales' : locales}) }}>
        </div>

    {% endif %}

{% endblock %}