{% extends 'admin/admin_base.html.twig' %}

{% block title %}{{ 'media.index.page_title' | trans({}, 'media') }}{% endblock %}

{% block body %}
    {{ breadcrumb(breadcrumb) }}

    <h1 class="head-title">
        <svg class="w-7 h-7 text-[var(--primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="m3 16 5-7 6 6.5m6.5 2.5L16 13l-4.286 6M14 10h.01M4 19h16a1 1 0 0 0 1-1V6a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1Z"></path>
        </svg>
        {{ 'media.index.page_title_h1' | trans({}, 'media') }}</h1>

    <div {{ vue_component('Admin/Content/Media/Mediatheque', {
        'url' : path('admin_media_load_medias'),
        'translate' : translate
    }) }}></div>

{% endblock %}