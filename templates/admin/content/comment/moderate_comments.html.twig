{% extends 'admin/admin_base.html.twig' %}

{% block title %}{{ 'comment.moderate.comments.page_title' | trans({}, 'comment') }}{% endblock %}

{% block body %}

    {{ breadcrumb(breadcrumb) }}

    <h1 class="head-title">
        <svg class="w-7 h-7 text-[var(--primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"></path>
        </svg>{{ 'comment.moderate.comments.page_title_h1' | trans({}, 'comment') }}</h1>

    <p class="text-sm mb-4" style="color: var(--text-secondary);">
        {{ 'comment.moderate.comments.description' | trans({}, 'comment') }}
    </p>

    <div {{ vue_component('Admin/Content/Comment/CommentModeration', {'urls' : urls, 'translate' : translate, 'datas' : datas}) }}></div>

{% endblock %}