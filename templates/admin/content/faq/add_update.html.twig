{% extends 'admin/admin_base.html.twig' %}


{% if id is same as null %}
    {% set title = 'faq.add.page_title' | trans({}, 'faq') %}
    {% set titleH1 = 'faq.add.page_title_h1' | trans({}, 'faq') %}
    {% set description = 'faq.add.description' | trans({}, 'faq') %}
{% else %}
    {% set title = 'faq.update.page_title' | trans({'id' : id}, 'faq') %}
    {% set titleH1 = 'faq.update.page_title_h1' | trans({}, 'faq') %}
    {% set description = 'faq.update.description' | trans({}, 'faq') %}
{% endif %}

 {% block title %}
     {{ title }}
 {% endblock %}

{% block body %}


    {{ breadcrumb(breadcrumb) }}

    {% if notFound === true %}
        <main class="flex-1 overflow-y-auto flex items-center justify-center p-6">
            <div class="flex flex-col items-center justify-center text-center max-w-sm">
                
                <div class="w-20 h-20 rounded-2xl flex items-center justify-center mb-6" style="background:var(--primary-lighter);">
                    <svg class="w-10 h-10" style="color:var(--primary);" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>

                <h2 class="text-xl font-bold mb-2" style="color:var(--text-primary);">
                    {{ 'faq.update.not.found.faq.title' | trans({}, 'faq') }}
                </h2>

                <p class="text-sm mb-8" style="color:var(--text-secondary);">
                    {{ 'faq.update.not.found.faq.description' | trans({}, 'faq') }}
                </p>

                <div class="flex items-center gap-3">
                    <a href="{{ path('admin_faq_index') }}" class="inline-flex items-center btn btn-sm btn-outline-dark">
                        <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                        </svg>
                        {{ 'faq.update.not.found.btn.return' | trans({}, 'faq') }}
                    </a>
                    <a href="{{ path('admin_faq_add') }}" class="inline-flex items-center btn btn-sm btn-primary">
                        <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path>
                        </svg>
                        {{ 'faq.update.not.found.btn.new_faq' | trans({}, 'faq') }}
                    </a>
                </div>

            </div>
        </main>
    {% else %}

        <h1 class="head-title">
            <svg class="w-7 h-7 text-[var(--primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M9.529 9.988a2.502 2.502 0 1 1 5 .191A2.441 2.441 0 0 1 12 12.582V14m-.01 3.008H12M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path>
            </svg>
            {{ titleH1 }}</h1>

        <p class="text-sm" style="color: var(--text-secondary);">
            {{ description }}
        </p>

        <div {{ vue_component('Admin/Content/Faq/Faq', {
            'id' : id,
            'urls' : urls,
            'translate' : translate,
            'locales' : locales,
        }) }}>
        </div>

    {% endif %}

{% endblock %}